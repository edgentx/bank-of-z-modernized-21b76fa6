# Bank-of-Z Teller — environment template.
# Copy to .env.local for local overrides; .env.local is gitignored.
#
# Public values (exposed to the browser bundle) must be NEXT_PUBLIC_*.
# Server-only secrets must NOT carry the NEXT_PUBLIC_ prefix.

NEXT_PUBLIC_APP_NAME=Bank-of-Z Teller
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api
NEXT_PUBLIC_ENVIRONMENT=development

# Server-side only.
API_REQUEST_TIMEOUT_MS=15000
