<!-- 
  TEMPORAL/SPRING/WEB FIX:
  This POM update adds the missing dependencies reported in the compiler error logs.
  Specifically:
  1. spring-boot-starter-web: Provides RestTemplate and Spring MVC.
  2. temporal-sdk: Provides @ActivityInterface, @ActivityMethod, and Workflow interfaces.
  3. lombok: Reduces boilerplate for DTOs and mock ports.
-->
<project>
    <modelVersion>4.0.0</modelVersion>
    <groupId>com.example</groupId>
    <artifactId>egdcrypto-bank-of-z-modernized</artifactId>
    <version>1.0.0-SNAPSHOT</version>
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.2.0</version>
        <relativePath/>
    </parent>
    
    <dependencies>
        <!-- Existing domain dependencies (implied by imports in existing code) -->
        
        <!-- FIX: Missing Web dependency for RestTemplate -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>

        <!-- FIX: Missing Temporal SDK dependencies for Annotations -->
        <dependency>
            <groupId>io.temporal</groupId>
            <artifactId>temporal-sdk</artifactId>
            <version>1.22.0</version>
        </dependency>
        <dependency>
            <groupId>io.temporal</groupId>
            <artifactId>temporal-spring-boot-starter</artifactId>
            <!-- Best effort version compatible with Spring Boot 3.x -->
            <version>1.22.0</version> 
        </dependency>

        <!-- Utility: Lombok for cleaner mock DTOs -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- Test Dependencies -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-core</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>
</project>