<!-- NOTE: Existing project dependencies assumed. Adding specific test dependencies for E2E validation. -->
<project>
    <modelVersion>4.0.0</modelVersion>
    
    <dependencies>
        <!-- Mockito for Mocking (Spring Boot BOM handles version) -->
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-core</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
        
        <!-- Awaitility for Temporal/Async assertion (Spring Boot BOM handles version) -->
        <dependency>
            <groupId>org.awaitility</groupId>
            <artifactId>awaitility</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Temporal Testing SDK (Not in Spring Boot BOM - Version Required) -->
        <dependency>
            <groupId>io.temporal</groupId>
            <artifactId>temporal-testing</artifactId>
            <version>1.22.0</version>
            <scope>test</scope>
        </dependency>
        
        <!-- Cucumber for E2E if needed, though JUnit is used here for unit regression -->
    </dependencies>
</project>