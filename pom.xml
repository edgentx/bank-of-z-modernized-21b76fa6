<!-- Fix for 'dependencies.dependency.version' for org.flywaydb:flyway-db2:jar is missing -->
<!-- The build error indicates that the BOM did not pin the version for flyway-db2, -->
<!-- so we must declare the version explicitly as per the project rules. -->
<project>
    <modelVersion>4.0.0</modelVersion>
    <groupId>com.example</groupId>
    <artifactId>bank-of-z</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <dependencies>
        <!-- Existing dependencies assumed to be present -->
        <dependency>
            <groupId>org.flywaydb</groupId>
            <artifactId>flyway-db2</artifactId>
            <version>9.22.3</version> <!-- Explicit version required as it is outside the strict BOM closed set -->
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-core</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>
</project>