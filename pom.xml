<!-- UPDATES TO pom.xml to fix build and add dependencies -->
<project>
    <modelVersion>4.0.0</modelVersion>
    <groupId>com.example</groupId>
    <artifactId>bank-of-z-modernization</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.2.3</version>
        <relativePath/>
    </parent>
    
    <dependencies>
        <!-- Core Spring Boot -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
        
        <!-- Testing -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-core</artifactId>
            <scope>test</scope>
        </dependency>
        
        <!-- Temporal (BOM does not cover, requires explicit version per Rule 9a) -->
        <dependency>
            <groupId>io.temporal</groupId>
            <artifactId>temporal-spring-boot-starter</artifactId>
            <version>1.22.1</version>
        </dependency>
        
        <!-- Flyway DB2 (BOM does not cover flyway-database-* modules, requires explicit version) -->
        <!-- Note: Maven Central typically uses flyway-database-db2, not flyway-db2. Using flyway-core for BOM match -->
        <dependency>
            <groupId>org.flywaydb</groupId>
            <artifactId>flyway-core</artifactId>
        </dependency>
        <!-- 
           NOTE: The error cited 'flyway-db2'. 
           If using the new DB2 support module introduced in Flyway 9.0+, the artifactId is 
           'flyway-database-db2' (org.flywaydb.group).
           We are adding explicit version logic to resolve the build error.
        -->
        <dependency>
            <groupId>org.flywaydb</groupId>
            <artifactId>flyway-database-db2</artifactId>
            <version>9.22.3</version>
        </dependency>
        
        <!-- IBM MQ / CICS (Simulated/Stubbed for build, but listed here as per error context) -->
        <!-- 
           com.ibm.cics:com.ibm.cics.server is typically in a private IBM repo. 
           For the purpose of this build fix, we comment it out or assume local install. 
           Since we cannot resolve private artifacts, we will assume the provided error 
           context implies we need to handle the dependency list.
        -->
    </dependencies>
    
    <repositories>
        <repository>
            <id>central</id>
            <url>https://repo.maven.apache.org/maven2</url>
        </repository>
    </repositories>
</project>