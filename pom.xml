<!--
  POM Update: Adding JUnit 5 and Mockito for testing.
  The dependencies below rely on the Spring Boot Parent BOM for version management.
-->
<project>
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.2.1</version>
        <relativePath/>
    </parent>
    
    <!-- ... existing dependencies ... -->

    <dependencies>
        <!-- Existing implementation dependencies would be here -->

        <!-- Test Dependencies -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-core</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <scope>test</scope>
        </dependency>
        <!-- 
           Note: Spring Boot Starter Test includes mockito-junit-jupiter (MockitoExtension). 
           This is sufficient to run the tests defined below.
        -->
    </dependencies>
</project>