<!--
  Project dependencies update for Defect Reporting / Slack Integration.
  Assuming Spring Boot Parent BOM is already present in the root pom.
-->
<project>
    <modelVersion>4.0.0</modelVersion>
    <groupId>com.example</groupId>
    <artifactId>bank-of-z-core</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <packaging>jar</packaging>

    <properties>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <dependencies>
        <!-- Spring Boot Starter is assumed to be managed by Parent BOM -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter</artifactId>
        </dependency>

        <!-- Testing: JUnit 5 (Jupiter) - Managed by Spring Boot BOM -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- 
           NOTE: No external HTTP client libraries (like OkHttp or Apache Commons)
           are added to the POM because we are using the Port/Adapter pattern.
           The actual implementation would use them, but for the TDD red phase,
           the MockSlackNotificationPort satisfies the interface.
        -->
    </dependencies>
</project>
